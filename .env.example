# ── SERVIDOR ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── BASE DE DATOS (PostgreSQL) ─────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=facturacion_8millas
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ── JWT AUTH ───────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_seguro
JWT_EXPIRES_IN=7d

# ── EMISOR (8 Millas) ──────────────────────────────────
EMISOR_RUC=20601234567
EMISOR_RAZON_SOCIAL=8 MILLAS S.A.C.
EMISOR_DIRECCION=Jr. General Prado 123, Huánuco
EMISOR_CIUDAD=Huánuco
EMISOR_UBIGEO=100101
EMISOR_ACTIVIDAD=Publicidad Exterior

# ── NUBEFACT OSE (SUNAT) ───────────────────────────────
NUBEFACT_TOKEN=tu_token_nubefact_aqui
NUBEFACT_URL=https://api.nubefact.com/api/v1

# ── FIREBASE USAGE — Almacenamiento real via Cloud Monitoring ──────
# Crear cuenta de servicio en: https://console.cloud.google.com/iam-admin/serviceaccounts
# Rol necesario: roles/monitoring.viewer (solo lectura de métricas)
# Descargar el JSON de la clave y pegarlo completo (en una sola línea) aquí:
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
FIREBASE_PROJECT_ID=tu-proyecto-firebase   # alternativa si no usas service account

# ── CLOUDINARY (eliminación de imágenes desde backend) ────────────
# Obtén estos valores en https://console.cloudinary.com → API Keys
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── GOOGLE CLOUD VISION (OCR) ──────────────────────────
# Obtén tu clave en https://console.cloud.google.com → APIs → Cloud Vision
# La clave NUNCA debe estar en el frontend; solo aquí en el backend.
GOOGLE_VISION_KEY=tu_google_vision_api_key_aqui

# ── VISTA360 API KEY ───────────────────────────────────
# Esta clave la configuras en tu app Vista360 (VITE_API_KEY)
VISTA360_API_KEY=genera_una_clave_aleatoria_aqui

# ── CORS ───────────────────────────────────────────────
ALLOWED_ORIGINS=https://tu-dominio.pages.dev,http://localhost:5173
