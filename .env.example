# ══════════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO — Sistema de Facturación 8 Millas
# Copia este archivo: cp .env.example .env
# NUNCA subas el .env real a GitHub
# ══════════════════════════════════════════════════════════════════

# ── SERVIDOR ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── JWT AUTH ───────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_seguro_minimo_32_chars
JWT_EXPIRES_IN=7d

# ── EMISOR (8 Millas) ──────────────────────────────────────────────
EMISOR_RUC=20615629431
EMISOR_RAZON_SOCIAL=8 MILLAS S.A.C.
EMISOR_DIRECCION=Jr. 28 de julio 1279
EMISOR_CIUDAD=Huánuco
EMISOR_UBIGEO=100101
EMISOR_ACTIVIDAD=Publicidad Exterior

# ── FIREBASE ADMIN SDK ─────────────────────────────────────────────
# El código lee FIREBASE_SERVICE_ACCOUNT (no GOOGLE_SERVICE_ACCOUNT_JSON)
# Descargar en: Firebase Console → Configuración → Cuentas de servicio
#   → Generar nueva clave privada (descarga un archivo .json)
# Pegar el JSON completo en UNA SOLA LÍNEA aquí:
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@proyecto.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── SUNAT API DIRECTA (gratuita) ───────────────────────────────────
#
# PASO 1 — Obtener Client ID y Secret:
#   https://sol.sunat.gob.pe → (inicia sesión con tu Clave SOL)
#   → Empresas → Comprobantes de Pago → API de Comprobantes
#   → "Mis aplicaciones" → "Nueva aplicación"
#   → Nombre: "Facturacion 8 Millas" → Copiar Client ID y Secret
#
SUNAT_CLIENT_ID=tu-client-id-de-sunat
SUNAT_CLIENT_SECRET=tu-client-secret-de-sunat
#
# PASO 2 — Usuario SOL (sin incluir el RUC delante):
#   Es el usuario con el que ingresas a sol.sunat.gob.pe
#   Ej: si entras con "20615629431MODDATOS", aquí va solo "MODDATOS"
#
SUNAT_SOL_USER=MODDATOS
SUNAT_SOL_PASSWORD=tu-clave-sol
#
# PASO 3 — Certificado digital .p12 (GRATIS desde SUNAT):
#   https://sol.sunat.gob.pe → Empresas → Comprobantes de Pago
#   → Certificado Digital → Generar certificado → descargar .p12
#
#   Convertir a base64 (ejecutar en tu máquina, NO en el servidor):
#     Mac/Linux: base64 -i certificado.p12 | tr -d '\n'
#     Windows:   [Convert]::ToBase64String([IO.File]::ReadAllBytes("certificado.p12"))
#
#   ⚠️  El resultado es una cadena muy larga en una sola línea, pégala aquí:
SUNAT_CERT_B64=base64-del-certificado-aqui
#
#   Contraseña que pusiste al generar el certificado en SUNAT:
SUNAT_CERT_PASS=contraseña-del-pfx
#
# PASO 4 — Modo de operación:
#   true  = Beta/pruebas (no afecta SUNAT real, usa para testear)
#   false = Producción real (comprobantes válidos ante SUNAT)
#
SUNAT_BETA=true

# ── CORS ───────────────────────────────────────────────────────────
# Separar múltiples orígenes con coma, sin espacios:
ALLOWED_ORIGINS=https://facturacion-web-abi.pages.dev,http://localhost:5173

# ── VISTA360 API KEY ───────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VISTA360_API_KEY=genera-una-clave-aleatoria-aqui

# ── CLOUDINARY (eliminación segura de imágenes) ────────────────────
# Obtener en: https://console.cloudinary.com → API Keys
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── GOOGLE CLOUD VISION (OCR de documentos) ────────────────────────
# Obtener en: https://console.cloud.google.com → APIs → Cloud Vision
GOOGLE_VISION_KEY=tu_google_vision_api_key
